# Local Docker MySQL root password. Change this after copying the file to .env.
MYSQL_ROOT_PASSWORD=replace-with-local-root-password

# Local development and test database settings.
DB_NAME=tanyourpeach
TEST_DB_NAME=tanyourpeach_test
DB_URL=jdbc:mysql://localhost:33306/tanyourpeach
TEST_DB_URL=jdbc:mysql://127.0.0.1:33306/tanyourpeach_test
DB_USERNAME=springboot
DB_PASSWORD=replace-with-local-app-password

# Valid local-only Base64 key for HS256. Replace it for any deployed environment.
JWT_SECRET=replace-with-base64-jwt-secret=
JWT_EXPIRATION_MS=86400000